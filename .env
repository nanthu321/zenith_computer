# Backend base URL — leave blank during development (Vite proxy handles it)
# Set for production builds: VITE_API_BASE_URL=https://backend-computer.onrender.com
VITE_API_BASE_URL=

# Set to "true" to force sample/demo data (no backend needed)
VITE_MOCK_MODE=false

# ── Scheduler / Polling Configuration ──
# Task polling interval in milliseconds (default: 60000 = 60 seconds)
# Minimum: 10000 (10s), Maximum: 300000 (5 minutes)
# Increase to reduce server load; decrease for more real-time task updates.
# Note: Real-time updates are delivered via SSE, so polling is only a fallback.
VITE_TASK_POLL_INTERVAL_MS=60000
